{
  "crons": [
    {
      "path": "/api/cron/sync-packages",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-updates",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/send-notifications",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/process-batches",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/cleanup-stale-jobs",
      "schedule": "*/5 * * * *"
    }
  ]
}
